@{
    ViewData["Title"] = "Leaderboard";
    var eventData = ViewBag.Event as CollegeEventPortal.Models.Event;
}

<div class="glass-card mb-4">
    <h2><i class="fas fa-trophy me-2"></i>Leaderboard</h2>
    <h4 class="text-muted">@eventData.Name</h4>
</div>

<div class="glass-card">
    @if (Model != null && ((dynamic)Model).Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>@(eventData.AllowTeamRegistration ? "Team Name" : "Participant Name")</th>
                        <th>Total Score</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int rank = 1;
                        foreach (var item in (dynamic)Model)
                        {
                            <tr class="@(rank <= 3 ? "table-warning" : "")">
                                <td>
                                    @if (rank == 1)
                                    {
                                        <i class="fas fa-trophy text-warning fa-lg"></i>
                                        <strong>#@rank</strong>
                                    }
                                    else if (rank == 2)
                                    {
                                        <i class="fas fa-medal text-secondary fa-lg"></i>
                                        <strong>#@rank</strong>
                                    }
                                    else if (rank == 3)
                                    {
                                        <i class="fas fa-medal text-danger fa-lg"></i>
                                        <strong>#@rank</strong>
                                    }
                                    else
                                    {
                                        <span>#@rank</span>
                                    }
                                </td>
                                <td><strong>@item.Name</strong></td>
                                <td><span class="badge bg-primary">@item.TotalScore points</span></td>
                            </tr>
                            rank++;
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-chart-line fa-4x text-muted mb-3"></i>
            <h4>No Scores Yet</h4>
            <p class="text-muted">Scores will appear here once judges start evaluating participants.</p>
        </div>
    }
</div>

<div class="glass-card mt-3">
    <a asp-action="EventDetails" asp-route-id="@eventData.Id" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to Event
    </a>
</div>
