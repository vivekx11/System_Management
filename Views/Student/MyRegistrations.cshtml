@model IEnumerable<CollegeEventPortal.Models.Registration>
@{
    ViewData["Title"] = "My Registrations";
}

<div class="glass-card mb-4">
    <h2><i class="fas fa-clipboard-list me-2"></i>My Registrations</h2>
    <p class="text-muted">View all your event registrations and their status</p>
</div>

@if (Model.Any())
{
    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Event Name</th>
                        <th>Event Type</th>
                        <th>Start Date</th>
                        <th>Team</th>
                        <th>Status</th>
                        <th>Registered On</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var registration in Model)
                    {
                        <tr>
                            <td>
                                <strong>@registration.Event.Name</strong>
                            </td>
                            <td>
                                @switch (registration.Event.EventType)
                                {
                                    case CollegeEventPortal.Models.EventType.DebuggingCompetition:
                                        <span class="badge bg-danger">Debugging</span>
                                        break;
                                    case CollegeEventPortal.Models.EventType.CodeInTheDark:
                                        <span class="badge bg-dark">Code in Dark</span>
                                        break;
                                    case CollegeEventPortal.Models.EventType.UIUXDesignChallenge:
                                        <span class="badge bg-primary">UI/UX</span>
                                        break;
                                }
                            </td>
                            <td>@registration.Event.StartDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (registration.Team != null)
                                {
                                    <span class="badge bg-info">@registration.Team.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">Solo</span>
                                }
                            </td>
                            <td>
                                @switch (registration.Status)
                                {
                                    case CollegeEventPortal.Models.RegistrationStatus.Pending:
                                        <span class="badge bg-warning">Pending</span>
                                        break;
                                    case CollegeEventPortal.Models.RegistrationStatus.Approved:
                                        <span class="badge bg-success">Approved</span>
                                        break;
                                    case CollegeEventPortal.Models.RegistrationStatus.Rejected:
                                        <span class="badge bg-danger">Rejected</span>
                                        break;
                                    case CollegeEventPortal.Models.RegistrationStatus.Cancelled:
                                        <span class="badge bg-secondary">Cancelled</span>
                                        break;
                                }
                            </td>
                            <td>@registration.RegisteredAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-action="EventDetails" asp-route-id="@registration.EventId" class="btn btn-sm btn-primary">
                                    <i class="fas fa-eye me-1"></i>View
                                </a>
                                @if (registration.Status == CollegeEventPortal.Models.RegistrationStatus.Approved)
                                {
                                    <a asp-action="Leaderboard" asp-route-eventId="@registration.EventId" class="btn btn-sm btn-info">
                                        <i class="fas fa-trophy me-1"></i>Leaderboard
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="glass-card text-center">
        <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
        <h4>No Registrations Yet</h4>
        <p class="text-muted">You haven't registered for any events yet.</p>
        <a asp-action="Events" class="btn btn-primary">
            <i class="fas fa-calendar-alt me-2"></i>Browse Events
        </a>
    </div>
}
