@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="glass-card">
            <h2><i class="fas fa-user-graduate me-2"></i>Welcome, @ViewBag.User.FullName!</h2>
            <p class="text-muted mb-0">@ViewBag.User.Department - Year @ViewBag.User.Year</p>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="glass-card text-center">
            <i class="fas fa-calendar-check fa-3x mb-3" style="color: #6366f1;"></i>
            <h3>@ViewBag.MyRegistrations.Count</h3>
            <p class="text-muted">My Registrations</p>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="glass-card text-center">
            <i class="fas fa-trophy fa-3x mb-3" style="color: #f59e0b;"></i>
            <h3>@ViewBag.UpcomingEvents.Count</h3>
            <p class="text-muted">Upcoming Events</p>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="glass-card text-center">
            <i class="fas fa-bell fa-3x mb-3" style="color: #ef4444;"></i>
            <h3>@ViewBag.Notifications.Count</h3>
            <p class="text-muted">Notifications</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8 mb-4">
        <div class="glass-card">
            <h4 class="mb-3"><i class="fas fa-calendar-alt me-2"></i>Upcoming Events</h4>
            @if (ViewBag.UpcomingEvents.Count > 0)
            {
                <div class="list-group">
                    @foreach (var evt in ViewBag.UpcomingEvents)
                    {
                        <a asp-action="EventDetails" asp-route-id="@evt.Id" class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between">
                                <h5 class="mb-1">@evt.Name</h5>
                                <small>@evt.StartDate.ToString("MMM dd")</small>
                            </div>
                            <p class="mb-1 text-muted">@evt.Venue</p>
                            <small><span class="badge bg-primary">@evt.EventType</span></small>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">No upcoming events available.</p>
            }
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="glass-card">
            <h4 class="mb-3"><i class="fas fa-bell me-2"></i>Notifications</h4>
            @if (ViewBag.Notifications.Count > 0)
            {
                <div class="list-group">
                    @foreach (var notification in ViewBag.Notifications)
                    {
                        <div class="list-group-item @(notification.IsRead ? "" : "list-group-item-info")">
                            <h6 class="mb-1">@notification.Title</h6>
                            <p class="mb-1 small">@notification.Message</p>
                            <small class="text-muted">@notification.CreatedAt.ToString("MMM dd, HH:mm")</small>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">No new notifications.</p>
            }
        </div>
    </div>
</div>

<div class="glass-card">
    <h4 class="mb-3"><i class="fas fa-list me-2"></i>My Recent Registrations</h4>
    @if (ViewBag.MyRegistrations.Count > 0)
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in ViewBag.MyRegistrations)
                    {
                        <tr>
                            <td>@reg.Event.Name</td>
                            <td>@reg.Event.StartDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (reg.Status == CollegeEventPortal.Models.RegistrationStatus.Approved)
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else if (reg.Status == CollegeEventPortal.Models.RegistrationStatus.Pending)
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@reg.Status</span>
                                }
                            </td>
                            <td>
                                <a asp-action="EventDetails" asp-route-id="@reg.EventId" class="btn btn-sm btn-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">You haven't registered for any events yet.</p>
        <a asp-action="Events" class="btn btn-primary">Browse Events</a>
    }
</div>
