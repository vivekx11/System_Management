@model IEnumerable<CollegeEventPortal.Models.Event>
@{
    ViewData["Title"] = "Browse Events";
}

<div class="glass-card mb-4">
    <h2><i class="fas fa-calendar-alt me-2"></i>Browse Events</h2>
    <p class="text-muted">Discover and register for exciting college events</p>
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var evt in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title">@evt.Name</h5>
                            @if (evt.Status == CollegeEventPortal.Models.EventStatus.RegistrationOpen)
                            {
                                <span class="badge bg-success">Open</span>
                            }
                            else if (evt.Status == CollegeEventPortal.Models.EventStatus.Published)
                            {
                                <span class="badge bg-info">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@evt.Status</span>
                            }
                        </div>
                        
                        <p class="card-text text-muted">
                            @(evt.Description?.Length > 100 ? evt.Description.Substring(0, 100) + "..." : evt.Description)
                        </p>
                        
                        <div class="mb-2">
                            <small class="text-muted">
                                <i class="fas fa-tag me-1"></i>
                                @switch (evt.EventType)
                                {
                                    case CollegeEventPortal.Models.EventType.DebuggingCompetition:
                                        <span class="badge bg-danger">Debugging Competition</span>
                                        break;
                                    case CollegeEventPortal.Models.EventType.CodeInTheDark:
                                        <span class="badge bg-dark">Code in the Dark</span>
                                        break;
                                    case CollegeEventPortal.Models.EventType.UIUXDesignChallenge:
                                        <span class="badge bg-primary">UI/UX Design</span>
                                        break;
                                }
                            </small>
                        </div>
                        
                        <div class="mb-2">
                            <small><i class="fas fa-calendar me-1"></i>@evt.StartDate.ToString("MMM dd, yyyy")</small>
                        </div>
                        
                        <div class="mb-2">
                            <small><i class="fas fa-map-marker-alt me-1"></i>@evt.Venue</small>
                        </div>
                        
                        <div class="mb-3">
                            <small><i class="fas fa-users me-1"></i>Max: @evt.MaxParticipants participants</small>
                        </div>
                        
                        @if (evt.AllowTeamRegistration)
                        {
                            <div class="mb-2">
                                <small class="text-info"><i class="fas fa-user-friends me-1"></i>Team Event (Max @evt.MaxTeamSize members)</small>
                            </div>
                        }
                        else
                        {
                            <div class="mb-2">
                                <small class="text-success"><i class="fas fa-user me-1"></i>Solo Event</small>
                            </div>
                        }
                        
                        <div class="d-grid gap-2">
                            <a asp-action="EventDetails" asp-route-id="@evt.Id" class="btn btn-primary">
                                <i class="fas fa-info-circle me-1"></i>View Details
                            </a>
                        </div>
                    </div>
                    
                    @if (evt.RegistrationDeadline > DateTime.UtcNow)
                    {
                        <div class="card-footer text-muted">
                            <small><i class="fas fa-clock me-1"></i>Registration closes: @evt.RegistrationDeadline.ToString("MMM dd, yyyy")</small>
                        </div>
                    }
                    else
                    {
                        <div class="card-footer bg-danger text-white">
                            <small><i class="fas fa-times-circle me-1"></i>Registration Closed</small>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="glass-card text-center">
        <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
        <h4>No Events Available</h4>
        <p class="text-muted">There are no events available at the moment. Check back later!</p>
    </div>
}
