@model CollegeEventPortal.Models.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
}

<div class="glass-card mb-4">
    <h2><i class="fas fa-user-circle me-2"></i>My Profile</h2>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="glass-card text-center">
            <div class="mb-3">
                <i class="fas fa-user-circle fa-5x text-primary"></i>
            </div>
            <h4>@Model.FullName</h4>
            <p class="text-muted">@Model.Email</p>
            @if (!string.IsNullOrEmpty(Model.RollNumber))
            {
                <p class="mb-0"><strong>Roll No:</strong> @Model.RollNumber</p>
            }
        </div>
    </div>
    
    <div class="col-md-8 mb-4">
        <div class="glass-card">
            <h4 class="mb-3">Personal Information</h4>
            
            <div class="row mb-3">
                <div class="col-sm-4"><strong>Full Name:</strong></div>
                <div class="col-sm-8">@Model.FullName</div>
            </div>
            
            <div class="row mb-3">
                <div class="col-sm-4"><strong>Email:</strong></div>
                <div class="col-sm-8">@Model.Email</div>
            </div>
            
            @if (!string.IsNullOrEmpty(Model.PhoneNumber))
            {
                <div class="row mb-3">
                    <div class="col-sm-4"><strong>Phone:</strong></div>
                    <div class="col-sm-8">@Model.PhoneNumber</div>
                </div>
            }
            
            @if (!string.IsNullOrEmpty(Model.RollNumber))
            {
                <div class="row mb-3">
                    <div class="col-sm-4"><strong>Roll Number:</strong></div>
                    <div class="col-sm-8">@Model.RollNumber</div>
                </div>
            }
            
            @if (!string.IsNullOrEmpty(Model.Department))
            {
                <div class="row mb-3">
                    <div class="col-sm-4"><strong>Department:</strong></div>
                    <div class="col-sm-8">@Model.Department</div>
                </div>
            }
            
            @if (Model.Year.HasValue)
            {
                <div class="row mb-3">
                    <div class="col-sm-4"><strong>Year:</strong></div>
                    <div class="col-sm-8">@Model.Year</div>
                </div>
            }
            
            <div class="row mb-3">
                <div class="col-sm-4"><strong>Account Created:</strong></div>
                <div class="col-sm-8">@Model.CreatedAt.ToString("MMMM dd, yyyy")</div>
            </div>
            
            <div class="row mb-3">
                <div class="col-sm-4"><strong>Status:</strong></div>
                <div class="col-sm-8">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="glass-card">
    <h4 class="mb-3">Quick Actions</h4>
    <div class="row">
        <div class="col-md-3 mb-2">
            <a asp-action="MyRegistrations" class="btn btn-outline-primary w-100">
                <i class="fas fa-clipboard-list me-2"></i>My Registrations
            </a>
        </div>
        <div class="col-md-3 mb-2">
            <a asp-controller="Team" asp-action="Index" class="btn btn-outline-info w-100">
                <i class="fas fa-users me-2"></i>My Teams
            </a>
        </div>
        <div class="col-md-3 mb-2">
            <a asp-action="Certificates" class="btn btn-outline-success w-100">
                <i class="fas fa-certificate me-2"></i>Certificates
            </a>
        </div>
        <div class="col-md-3 mb-2">
            <a asp-action="Events" class="btn btn-outline-warning w-100">
                <i class="fas fa-calendar me-2"></i>Browse Events
            </a>
        </div>
    </div>
</div>
