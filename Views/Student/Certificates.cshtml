@model IEnumerable<CollegeEventPortal.Models.Certificate>
@{
    ViewData["Title"] = "My Certificates";
}

<div class="glass-card mb-4">
    <h2><i class="fas fa-certificate me-2"></i>My Certificates</h2>
    <p class="text-muted">View and download your achievement certificates</p>
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var certificate in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <i class="fas fa-award fa-4x text-warning"></i>
                        </div>
                        
                        <h5 class="card-title text-center">@certificate.Event.Name</h5>
                        
                        <div class="text-center mb-3">
                            <span class="badge bg-primary fs-6">Rank: @certificate.Rank</span>
                        </div>
                        
                        <hr />
                        
                        <div class="mb-2">
                            <small class="text-muted">Certificate Number:</small>
                            <p class="mb-0"><code>@certificate.CertificateNumber</code></p>
                        </div>
                        
                        <div class="mb-3">
                            <small class="text-muted">Issued On:</small>
                            <p class="mb-0">@certificate.IssuedAt.ToString("MMMM dd, yyyy")</p>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <a asp-controller="Certificate" asp-action="Download" asp-route-id="@certificate.Id" class="btn btn-success">
                                <i class="fas fa-download me-2"></i>Download PDF
                            </a>
                            <a asp-controller="Certificate" asp-action="Verify" asp-route-certificateNumber="@certificate.CertificateNumber" class="btn btn-outline-info" target="_blank">
                                <i class="fas fa-check-circle me-2"></i>Verify Certificate
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="glass-card text-center">
        <i class="fas fa-certificate fa-4x text-muted mb-3"></i>
        <h4>No Certificates Yet</h4>
        <p class="text-muted">You haven't earned any certificates yet. Participate in events to earn certificates!</p>
        <a asp-action="Events" class="btn btn-primary">
            <i class="fas fa-calendar-alt me-2"></i>Browse Events
        </a>
    </div>
}
