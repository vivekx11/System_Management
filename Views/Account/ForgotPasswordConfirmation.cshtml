@{
    ViewData["Title"] = "Password Reset Email Sent";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="glass-card text-center">
            <i class="fas fa-check-circle fa-5x text-success mb-4"></i>
            <h2>Check Your Email</h2>
            <p class="lead">We've sent you a password reset link.</p>
            <p class="text-muted">Please check your email and click on the link to reset your password.</p>
            
            @if (TempData["ResetLink"] != null)
            {
                <div class="alert alert-info mt-4">
                    <strong>Development Mode:</strong><br />
                    <small>In production, this link would be sent via email.</small><br />
                    <a href="@TempData["ResetLink"]" class="btn btn-sm btn-primary mt-2">Reset Password</a>
                </div>
            }
            
            <div class="mt-4">
                <a asp-action="Login" class="btn btn-primary">
                    <i class="fas fa-sign-in-alt me-2"></i>Back to Login
                </a>
            </div>
        </div>
    </div>
</div>
