@{
    ViewData["Title"] = "Password Reset Successful";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="glass-card text-center">
            <i class="fas fa-check-circle fa-5x text-success mb-4"></i>
            <h2>Password Reset Successful!</h2>
            <p class="lead">Your password has been reset successfully.</p>
            <p class="text-muted">You can now login with your new password.</p>
            
            <div class="mt-4">
                <a asp-action="Login" class="btn btn-primary btn-lg">
                    <i class="fas fa-sign-in-alt me-2"></i>Login Now
                </a>
            </div>
        </div>
    </div>
</div>
