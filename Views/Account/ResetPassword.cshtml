@model CollegeEventPortal.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="glass-card">
            <div class="text-center mb-4">
                <i class="fas fa-lock fa-4x text-primary mb-3"></i>
                <h2>Reset Password</h2>
                <p class="text-muted">Enter your new password</p>
            </div>
            
            <form asp-action="ResetPassword" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />
                
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" placeholder="Enter new password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm new password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                
                <div class="alert alert-info">
                    <small>
                        <strong>Password Requirements:</strong>
                        <ul class="mb-0">
                            <li>At least 6 characters</li>
                            <li>Contains uppercase and lowercase letters</li>
                            <li>Contains at least one digit</li>
                        </ul>
                    </small>
                </div>
                
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check me-2"></i>Reset Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
