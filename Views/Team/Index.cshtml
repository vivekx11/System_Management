@model IEnumerable<CollegeEventPortal.Models.Team>
@{
    ViewData["Title"] = "My Teams";
}

<div class="glass-card mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2><i class="fas fa-users me-2"></i>My Teams</h2>
            <p class="text-muted mb-0">Manage your team memberships</p>
        </div>
        <div>
            <a asp-action="Join" class="btn btn-primary">
                <i class="fas fa-user-plus me-2"></i>Join Team
            </a>
        </div>
    </div>
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var team in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title">@team.Name</h5>
                            @if (team.Status == CollegeEventPortal.Models.TeamStatus.Active)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@team.Status</span>
                            }
                        </div>
                        
                        <div class="mb-2">
                            <small class="text-muted">Event:</small>
                            <p class="mb-0"><strong>@team.Event.Name</strong></p>
                        </div>
                        
                        <div class="mb-2">
                            <small class="text-muted">Invite Code:</small>
                            <p class="mb-0"><code class="bg-light p-1">@team.InviteCode</code></p>
                        </div>
                        
                        <div class="mb-2">
                            <small class="text-muted">Team Leader:</small>
                            <p class="mb-0">@team.Leader.FullName</p>
                        </div>
                        
                        <div class="mb-3">
                            <small class="text-muted">Members:</small>
                            <p class="mb-0">@team.Members.Count / @team.Event.MaxTeamSize</p>
                            <div class="progress" style="height: 5px;">
                                <div class="progress-bar" role="progressbar" style="width: @((team.Members.Count * 100.0 / team.Event.MaxTeamSize))%"></div>
                            </div>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <a asp-action="Details" asp-route-id="@team.Id" class="btn btn-primary">
                                <i class="fas fa-eye me-1"></i>View Details
                            </a>
                        </div>
                    </div>
                    <div class="card-footer text-muted">
                        <small><i class="fas fa-calendar me-1"></i>Created: @team.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="glass-card text-center">
        <i class="fas fa-users-slash fa-4x text-muted mb-3"></i>
        <h4>No Teams Yet</h4>
        <p class="text-muted">You haven't joined or created any teams yet.</p>
        <div class="mt-3">
            <a asp-action="Join" class="btn btn-primary me-2">
                <i class="fas fa-user-plus me-2"></i>Join a Team
            </a>
            <a asp-controller="Student" asp-action="Events" class="btn btn-outline-primary">
                <i class="fas fa-calendar-alt me-2"></i>Browse Events
            </a>
        </div>
    </div>
}
