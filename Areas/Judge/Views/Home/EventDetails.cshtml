@model CollegeEventPortal.Models.Event
@{
    ViewData["Title"] = "Event Details";
}

<div class="container py-4">
    <h2 class="mb-4">@Model.Name</h2>

    <div class="card mb-4">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Event Type</dt>
                <dd class="col-sm-9">@Model.EventType</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                <dt class="col-sm-3">Start Date</dt>
                <dd class="col-sm-9">@Model.StartDate.ToString("MMM dd, yyyy HH:mm")</dd>

                <dt class="col-sm-3">End Date</dt>
                <dd class="col-sm-9">@Model.EndDate.ToString("MMM dd, yyyy HH:mm")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-@(Model.Status == CollegeEventPortal.Models.EventStatus.Ongoing ? "success" : "secondary")">
                        @Model.Status
                    </span>
                </dd>

                <dt class="col-sm-3">Registration Type</dt>
                <dd class="col-sm-9">@(Model.AllowTeamRegistration ? "Team" : "Solo")</dd>

                <dt class="col-sm-3">Max Participants</dt>
                <dd class="col-sm-9">@Model.MaxParticipants</dd>
            </dl>
        </div>
    </div>

    @if (Model.AllowTeamRegistration)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5>Registered Teams</h5>
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Team Name</th>
                            <th>Leader</th>
                            <th>Members</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var team in Model.Teams)
                        {
                            <tr>
                                <td>@team.Name</td>
                                <td>@team.Leader.FullName</td>
                                <td>@team.Members.Count</td>
                                <td>@team.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5>Registered Participants</h5>
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Registered At</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reg in Model.Registrations)
                        {
                            <tr>
                                <td>@reg.User.FullName</td>
                                <td>@reg.User.Email</td>
                                <td>@reg.RegisteredAt.ToString("MMM dd, yyyy")</td>
                                <td>@reg.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="d-flex gap-2">
        <a asp-action="ScoreParticipants" asp-route-eventId="@Model.Id" class="btn btn-success">Score Participants</a>
        <a asp-action="Leaderboard" asp-route-eventId="@Model.Id" class="btn btn-info">View Leaderboard</a>
        <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
